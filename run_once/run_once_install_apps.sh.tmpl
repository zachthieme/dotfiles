#!/bin/sh

######## GLOBAL 

# install starship
which starship
if [ $? -eq 1 ]; then
  curl -sS https://starship.rs/install.sh | sh
fi

# install cargo and rust
which cargo
if [ $? -eq 1 ]; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
fi


######## LINUX 
{{- if eq .chezmoi.os "linux" }}

# Add repo for neovim
sudo add-apt-repository ppa:neovim-ppa/stable

sudo apt update && sudo apt upgrade -y  

sudo apt install -y bat exa fd-find fzf gh git jq mosh neovim pandoc pass ripgrep tmux vim zsh

# install rargs
which rargs
if [ $? -eq 1 ]; then
  cargo install --git https://github.com/lotabout/rargs.git
fi

# install zoxide
which zoxide
if [ $? -eq 1 ]; then
  curl -sSfL https://raw.githubusercontent.com/ajeetdsouza/zoxide/main/install.sh | sh
fi

{{- end }}

######## MAC 
{{- if eq .chezmoi.os "darwin" }}

if ! command -v brew &> /dev/null
then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew update

# Install common packages
brew install bat fd fzf gh git jq jupyterlab neovim pandoc pass rargs ripgrep skhd tmux vim wget yabai zoxide zsh 

{{- end }}
