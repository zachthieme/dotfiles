#!/bin/bash

echo "########################################################"
echo "Starting global install!"
echo "########################################################"

# install starship
which starship
if [ $? -eq 1 ]; then
  curl -sS https://starship.rs/install.sh | sh
fi

# install cargo and rust
which cargo
if [ $? -eq 1 ]; then
  curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh
fi

# install exa
which exa
if [ $? -eq 1 ]; then
  cargo install exa 
fi

# add nvm and npm
nvm --help
if [ $? -eq 1 ]; then
  curl -o- https://raw.githubusercontent.com/nvm-sh/nvm/v0.39.7/install.sh | bash
  nvm install node
fi

# install rargs
which rargs
if [ $? -eq 1 ]; then
  cargo install --git https://github.com/lotabout/rargs.git
fi

INSTALL=( bat fzf gh git jq mosh pandoc pass ripgrep tmux vim wget zoxide zsh )
LINUX=( fd-find software-properties-common python3-launchpadlib ninja-build gettext libtool libtool-bin autoconf automake cmake g++ pkg-config unzip curl doxygen )

{{- if eq .chezmoi.osRelease.id "debian" }}

echo "########################################################"
echo "Starting Raspberry Pi install!"
echo "########################################################"
sudo apt update && sudo apt upgrade -y  

echo ${INSTALL[@]} | xargs sudo apt install -y 
echo ${LINUX[@]} | xargs sudo apt install -y 

# Add neovim
which nvim
if [ $? -eq 1 ]; then
  git clone --depth=1 https://github.com/neovim/neovim
  cd neovim && make CMAKE_BUILD_TYPE=RelWithDebInfo
  git checkout stable
  sudo make install
fi

# install rargs
which rargs
if [ $? -eq 1 ]; then
  cargo install --git https://github.com/lotabout/rargs.git
fi

{{- end }}

########################################################
######## Pop!OS 
########################################################

{{- if eq .chezmoi.osRelease.name "Pop!_OS" }}

echo "########################################################"
echo "Starting Pop!OS install!"
echo "########################################################"

# Add repo for neovim
apt-cache policy | grep neovim
if [ $? -eq 1 ]; then
  sudo add-apt-repository ppa:neovim-ppa/stable
fi

sudo apt update && sudo apt upgrade -y  

sudo apt install -y neovim
echo ${INSTALL[@]} | xargs sudo apt install -y 
echo ${LINUX[@]} | xargs sudo apt install -y 

{{- end }}

{{- if eq .chezmoi.os "darwin" }}

echo "########################################################"
echo "Starting Mac Install"
echo "########################################################"

if ! command -v brew &> /dev/null
then
    /bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"
fi

brew update

# Install common packages
brew install fd skhd yabai neovim 
echo ${INSTALL[@]} | xargs brew install  

{{- end }}
