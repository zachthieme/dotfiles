yabai -m signal --add event=dock_did_restart action="sudo yabai --load-sa"
sudo yabai --load-sa

# default layout (can be bsp, stack or float)
yabai -m config layout bsp

# New window spawns to the right if vertical split, or bottom if horizontal split
yabai -m config window_placement second_child

# padding set to 12px
yabai -m config top_padding 3 
yabai -m config bottom_padding 3
yabai -m config left_padding 3
yabai -m config right_padding 3
yabai -m config window_gap 10

# modifier for clicking and dragging with mouse
yabai -m config mouse_modifier alt
# set modifier + left-click drag to move window
yabai -m config mouse_action1 move
# set modifier + right-click drag to resize window
yabai -m config mouse_action2 resize

yabai -m config normal_window_border_color   0x00FFFFFF
yabai -m config active_window_border_color   0xff00ca4e
yabai -m config window_opacity               off
#yabai -m config normal_window_opacity        1
yabai -m config window_border_width          3              
yabai -m config window_border_radius         12             
yabai -m config window_border_blur           off            
yabai -m config window_border_hidpi          on             
yabai -m config window_border                on             

# do not manage windows
yabai -m rule --add label="Finder" app="^Finder$" title="(Co(py|nnect)|Move|Info|Pref)" manage=off
yabai -m rule --add label="Safari" app="^Safari$" title="^(General|(Tab|Password|Website|Extension)s|AutoFill|Se(arch|curity)|Privacy|Advance)$" manage=off
yabai -m rule --add label="QuickTime Player" app="QuickTime Player" manage=off
yabai -m rule --add label="App Store" app="^App Store$" manage=off
yabai -m rule --add label="Activity Monitor" app="^Activity Monitor$" manage=off
yabai -m rule --add label="Software Update" title="Software Update" manage=off
yabai -m rule --add label="About This Mac" app="System Information" manage=off
yabai -m rule --add app="^System Settings$" manage=off
yabai -m rule --add app="^Logi Options$" manage=off
yabai -m rule --add app="^Calculator$" manage=off
yabai -m rule --add app="^Karabiner-Elements$" manage=off
yabai -m rule --add app="^Fig$" manage=off
yabai -m rule --add app="^Cisco AnyConnect Secure Mobility Client$" manage=off

# set to always on top
yabai -m rule --add app="^Tana$" manage=off sticky=on layer=above

# Rules to move windows to the right space
yabai -m space 1 --label term
yabai -m rule --add app="^Tabby$" space=1

yabai -m space 2 --label mail
yabai -m rule --add app="^Mail - Zach Thieme - Outlook$" space=2
yabai -m rule --add app="^Outlook \(PWA\)$" space=2

yabai -m space 3 --label txt
yabai -m rule --add app="^Messages$" space=3
yabai -m rule --add app="^Slack$" space=3

# keep next two lines in current order due to inheritence of the rules
yabai -m space 5 --label conf
yabai -m rule --add app="^(Zoom|Microsoft Teams)$" space=5

yabai -m space 4 --label cal
yabai -m rule --add app="^Microsoft Teams$" title="^Calendar | Microsoft Teams$" space=4

yabai -m space 6 --label music
yabai -m rule --add app="^(Spotify|Music)$" space=6
